{
  "name": "mygame-library",
  "version": "0.0.1",
  "description": "Stencil Component Starter",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/mygame-library/mygame-library.esm.js",
  "exports": {
    ".": {
      "import": "./dist/mygame-library/mygame-library.esm.js",
      "require": "./dist/mygame-library/mygame-library.cjs.js"
    },
    "./my-component": {
      "import": "./dist/components/my-component.js",
      "types": "./dist/components/my-component.d.ts"
    },
    "./loader": {
      "import": "./loader/index.js",
      "require": "./loader/index.cjs",
      "types": "./loader/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stenciljs/component-starter.git"
  },
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "build": "stencil build",
    "start": "stencil build --dev --watch --serve",
    "test": "stencil-test --prod",
    "test:watch": "stencil-test --prod --watch",
    "generate": "stencil generate",
    "storybook": "storybook dev -p 6006 --no-open"
  },
  "devDependencies": {
    "@stencil/core": "^4.43.5",
    "@stencil/sass": "^3.2.3",
    "@stencil/storybook-plugin": "^0.7.0",
    "@stencil/vitest": "^1.13.2",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-links": "^10.4.6",
    "@types/node": "^22.13.5",
    "@vitest/browser-playwright": "^4.0.0",
    "playwright": "^1.52.0",
    "storybook": "^10.4.6",
    "vitest": "^4.0.0"
  },
  "overrides": {
    "sass-embedded": "1.97.3"
  },
  "license": "MIT"
}
